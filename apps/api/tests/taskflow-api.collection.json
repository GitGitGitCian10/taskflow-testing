    {
      "name": "Tareas",
      "item": [
        {
          "name": "Crear tarea (US-05)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Tarea creada con status TODO', () => {\r",
                  "    pm.response.to.have.status(201);\r",
                  "    const body = pm.response.json();\r",
                  "    pm.expect(body.status).to.eql('TODO');\r",
                  "    pm.environment.set('task_id', body.id);\r",
                  "});\r",
                  "\r",
                  "pm.test('Priority HIGH se persistió correctamente', () => {\r",
                  "    pm.expect(pm.response.json().priority).to.eql('HIGH');\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"title\": \"Configurar colección Postman\",\r\n    \"priority\": \"HIGH\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/tasks",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "projects",
                "{{project_id}}",
                "tasks"
              ]
            },
            "description": "US-05 — Crear tarea  \nCA verificado: Tarea creada exitosamente con prioridad 'HIGH' → status 201 y priority 'HIGH'  \nTipo de test: Funcional  \nResultado esperado: 201 Created con status 'TODO' y priority 'HIGH'"
          },
          "response": []
        },
        {
          "name": "Avanzar a IN_PROGRESS",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "})\r",
                  "\r",
                  "pm.test('Transición valida TODO -> IN_PROGRESS', () => {\r",
                  "    const body = pm.response.json();\r",
                  "    pm.expect(body.statusHistory[0].from).to.eql('TODO');\r",
                  "    pm.expect(body.statusHistory[0].to).to.eql('IN_PROGRESS');\r",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
