      "name": "Proyectos",
      "item": [
        {
          "name": "Crear proyecto (US-03)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Proyecto creado con status 201', () => {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test('Response tiene id, name y status activo', () => {\r",
                  "    const body = pm.response.json();\r",
                  "    pm.expect(body.id).to.be.a('string');\r",
                  "    pm.expect(body.name).to.eql('Mi proyecto de testing');\r",
                  "    // Guardar ID para los siguientes requests\r",
                  "    pm.environment.set('project_id', body.id);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"name\": \"Mi proyecto de testing\",\r\n    \"description\": \"Creado en la práctica Clase 4\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
