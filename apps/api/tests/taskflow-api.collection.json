      "name": "Autenticación",
      "item": [
        {
          "name": "Registro de usuario (US-01)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test('Response tiene id y email', () => {\r",
                  "    const body = pm.response.json();\r",
                  "    pm.expect(body.user).to.have.property('id');\r",
                  "    pm.expect(body.user.email).to.eql('ana7@ejemplo.com');\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"name\": \"Ana García 7\",\r\n    \"email\": \"ana7@ejemplo.com\",\r\n    \"password\": \"Segura123!\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
